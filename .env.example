# Postgres (Neon via Vercel Marketplace recommended).
# If unset, the API still works but skips cache reads/writes.
DATABASE_URL=

# Open Food Facts requires a descriptive user agent on all requests.
OFF_USER_AGENT=GuardScan/1.0 (aristides.nakos@gmail.com)

# Auth. M1 accepts a dev header bypass; production enables JWT verification.
AUTH_ENABLED=false
SUPABASE_JWT_SECRET=

# Commercial fallback — deferred (see charter §13.1). Leave disabled in v1.
PROVIDER_FALLBACK_ENABLED=false
PROVIDER_API_KEY=

# Structured logging level
LOG_LEVEL=info
